<Page
    x:Class="HAWindowsCompanion.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button 
                Command="{x:Bind ViewModel.NavigateToMainCommand}"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Padding="8"
                Margin="0 4 0 0"
                Background="Transparent"
                BorderBrush="Transparent"
                ToolTipService.ToolTip="Back to main page"
                AutomationProperties.Name="back">
                <SymbolIcon Symbol="Back" />
            </Button>

            <TextBlock 
                Grid.Column="1" 
                Text="Settings" 
                Style="{StaticResource TitleTextBlockStyle}" 
                VerticalAlignment="Center"
                Margin="12,0,0,0" />
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="24" Spacing="24">
                <StackPanel Spacing="8">
                    <TextBlock Text="General" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ToggleSwitch Header="Launch at Windows Startup" IsOn="{x:Bind ViewModel.LaunchAtStartup, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Sensors" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <NumberBox Header="Update Interval (Seconds)" Value="{x:Bind ViewModel.UpdateInterval, Mode=TwoWay}" SmallChange="5" LargeChange="30" SpinButtonPlacementMode="Compact" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock 
                        Text="Debugging" 
                        Style="{StaticResource SubtitleTextBlockStyle}" />

                    <!-- Restart notice (only visible when required) -->
                    <InfoBar
                        x:Name="RestartInfoBar"
                        Severity="Warning"
                        IsOpen="{x:Bind ViewModel.IsRestartRequired, Mode=OneWay}"
                        Title="Restart Required"
                        Message="The change will take effect after restarting the application.">
                        <InfoBar.ActionButton>
                            <Button 
                                Content="Restart App"
                                Command="{x:Bind ViewModel.RestartApplicationCommand}"
                                AutomationProperties.Name="Restart application" />
                        </InfoBar.ActionButton>
                    </InfoBar>

                    <ToggleSwitch 
                        Header="Enable File Logging"
                        IsOn="{x:Bind ViewModel.IsFileLoggingEnabled, Mode=TwoWay}"
                        OnContent="Enabled"
                        OffContent="Disabled"
                        AutomationProperties.Name="Enable or disable file logging" />

                    <TextBlock 
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Margin="0,4,0,0">
                        <Run Text="Writes detailed logs to:" />
                        <LineBreak />
                        <Run Text="%LOCALAPPDATA%\HAWindowsCompanion\logs\" FontFamily="Consolas" />
                        <LineBreak />
                        <Run Text="Format: [YYYY-MM-DD HH:mm:ss] [Level] Category: Message" FontFamily="Consolas" FontSize="11" />
                    </TextBlock>

                    <HyperlinkButton 
                        Content="Open Log Folder"
                        Command="{x:Bind ViewModel.OpenLogFolderCommand}"
                        Margin="0,8,0,0"
                        BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                        AutomationProperties.Name="Open log folder in Explorer" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock
                        Text="Danger Zone"
                        Style="{StaticResource SubtitleTextBlockStyle}" />

                    <TextBlock
                    Text="Reconnect"
                    Margin="4 0 0 0"
                    Style="{StaticResource BodyLargeStrongTextBlockStyle}" />

                    <StackPanel
                        Margin="8 0 0 0">

                        <TextBlock
                            TextWrapping="Wrap"
                            Margin="0,4,0,0">
                            <Run Text="This will launch the setup wizard to reconnect the app to Home Assistant." />
                        </TextBlock>
                        <TextBlock
                            TextWrapping="Wrap"
                            Margin="0,4,0,0">
                            <Run Text="The device ID remains unchanged, so Home Assistant will recognise the app as the same device if it was previously connected to this instance." />
                        </TextBlock>
                        <TextBlock
                            TextWrapping="Wrap"
                            Margin="0,4,0,0">
                            <Run Text="Home Assistant will reuse an existing device even if it has been deleted." />
                        </TextBlock>
                        <HyperlinkButton
                            Content="Launch setup wizard"
                            Command="{x:Bind ViewModel.NavigateToSetupWizardCommand}"
                            Margin="0,8,0,0"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                            AutomationProperties.Name="Launch the setup wizard" />
                    </StackPanel>


                    <TextBlock
                    Text="App Reset"
                    Margin="4 0 0 0"
                    Style="{StaticResource BodyLargeStrongTextBlockStyle}" />

                    <StackPanel
                        Margin="8 0 0 0">

                        <TextBlock
                            TextWrapping="Wrap"
                            Margin="0,4,0,0">
                            <Run Text="This will reset all the app’s settings, and you will need to reconfigure the app and connect it to Home Assistant." />
                        </TextBlock>
                        <TextBlock
                            TextWrapping="Wrap"
                            Margin="0,4,0,0">
                            <Run Text="The device ID is regenerated, so the app is recognised by Home Assistant as a completely new device." />
                        </TextBlock>
                        <TextBlock
                            TextWrapping="Wrap"
                            Margin="0,4,0,0">
                            <Run Text="This action cannot be undone!" Foreground="Red" />
                        </TextBlock>
                        <HyperlinkButton
                            Content="Reset all settings"
                            Command="{x:Bind ViewModel.ResetSettingsCommand}"
                            Margin="0,8,0,0"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                            AutomationProperties.Name="Reset all application settings" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
