<Page
    x:Class="HAWindowsCompanion.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:HAWindowsCompanion.App.ViewModels"
    NavigationCacheMode="Enabled">

    <Grid Padding="24">
        <StackPanel Spacing="12">
            <TextBlock Text="Home Assistant Companion" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="{x:Bind ViewModel.ServerUrl, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.6" />
            
            <InfoBar Title="Status" Message="{x:Bind ViewModel.ConnectionStatus, Mode=OneWay}" IsOpen="True" Severity="Informational" />

            <TextBlock Text="Active Sensors" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,4" />
            <ListView ItemsSource="{x:Bind ViewModel.ActiveSensors}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:SensorInfo">
                        <Grid Padding="0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{x:Bind Value}" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
